# ─────────────────────────────────────────
# JD & Resume Parser – environment variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────

# ── OpenAI ───────────────────────────────
OPENAI_API_KEY=sk-...

# ── Supabase ─────────────────────────────
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_KEY=<your-supabase-anon-or-service-key>

# ── Ontology / Skill Resolver ─────────────
# Table name in Supabase that holds skill nodes
SKILL_NODES_TABLE=skill_nodes
# Table name in Supabase that holds skill aliases
SKILL_ALIASES_TABLE=skill_aliases
# Enable fuzzy matching (true/false)
FUZZY_MATCH_ENABLED=false
# Fuzzy-match similarity threshold (0-100)
FUZZY_THRESHOLD=90
